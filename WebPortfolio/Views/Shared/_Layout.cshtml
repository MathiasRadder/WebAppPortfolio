<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Portfolio</title>
	<script type="importmap"></script>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/WebPortfolio.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>
<body>
	<header>
      <nav class="navbar navbar-expand navbar-toggleable-sm navbar-dark NavBarBorder mb-3 NavColor border-bottom sticky-top">
			<div class="container-fluid">
				<a class="navbar-brand text-dark" asp-area="" asp-controller="Home" asp-action="Index">Portfolio</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
					<ul class="navbar-nav flex-grow-1">
						<li class="nav-item">
							<a class="nav-link NavButton d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
						</li>
					</ul>
					<div id="NavTitle">
						<h2>Mathias Portfolio</h2>
					</div>
					<div id="ResourcesNav">
						<a class="nav-item LinksNav" href="mailto:mathias.radder@hotmail.com">
							<i class="bi bi-envelope"></i>
						</a>
						<a class="nav-item LinksNav" href="https://www.linkedin.com/in/mathias-radder-953841251/">
							<i class="bi bi-linkedin"></i>
						</a>
						<a class="nav-link NavButton nav-item" href="~/resources/Mathias_Radder_CV_English.pdf">CV EN</a>
						<a class="nav-link NavButton nav-item" href="~/resources/Mathias_Radder_CV_Nederlands.pdf">CV NL</a>
					</div>

				</div>
			</div>
		</nav>
	</header>
	<!-- spacer to offset the fixed navbar so page content isn't hidden -->
	<div class="navbar-spacer"></div>
	<div class="container">
		<main role="main" class="pb-3" id="MainBackground">
			@RenderBody()
		</main>
	</div>

	<footer class="border-top footer text-muted NavColor">
		<div class="container FooterLinks">
			<a class="" href="mailto:mathias.radder@hotmail.com">
				<i class="bi bi-envelope"></i>
			</a>
			<a class="" href="https://www.linkedin.com/in/mathias-radder-953841251/">
				<i class="bi bi-linkedin"></i>
			</a>
		</div>
	</footer>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
